# ─── Provider API Keys (BYOK) ─────────────────────────────────────────────
# Provide one or more. Whichever provider you select must have a valid key.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# ─── Local LLM Endpoints (no key needed) ──────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# ─── Provider Routing ─────────────────────────────────────────────────────
# Active provider: anthropic | openai | ollama | lmstudio | deepseek | openrouter
COWORK_PROVIDER=ollama
COWORK_MODEL=qwen2.5-coder:7b

# ─── Agent Engine ─────────────────────────────────────────────────────────
COWORK_MAX_TURNS=50
COWORK_LOG_LEVEL=info
COWORK_PERMISSION_MODE=standard
COWORK_CONTEXT_WINDOW=100000

# ─── Vector Search (optional — falls back to BM25 if absent) ──────────────
# Any OpenAI-compatible /v1/embeddings endpoint
# Recommended: ollama pull nomic-embed-text
COWORK_EMBEDDER_URL=http://localhost:11434/v1
COWORK_EMBEDDER_MODEL=nomic-embed-text
# COWORK_EMBEDDER_API_KEY=
