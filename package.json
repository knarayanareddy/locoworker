{
  "name": "locoworker",
  "version": "0.1.0",
  "private": true,
  "description": "Claude CoWork — BYOK + Local LLM agentic coding workspace",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "cowork": "bun run apps/cowork-cli/src/index.ts",
    "dashboard": "bun run apps/dashboard/src/server.ts",
    "hermes": "bun run packages/hermes/src/bin.ts",
    "typecheck": "tsc --build --noEmit",
    "test": "bun test",
    "build:all": "bun run --filter='*' build"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "@types/node": "^22.5.0",
    "@types/bun": "^1.1.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
